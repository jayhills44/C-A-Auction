# Copy this file to .env.local and fill in your Firebase values.
# See SETUP.md for exactly where to find these.

# ---- Client-side (safe to expose in the browser) ----
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---- Server-side (KEEP SECRET) ----
# From your Firebase service account JSON.
# The private key MUST have literal \n for line breaks (do not paste the raw newlines).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
